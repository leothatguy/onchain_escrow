# ─── PNPM CONFIG ─────────────────────────────────────────────────
# Lucid Evolution depends on libsodium-wrappers-sumo which has a
# ESM import of ./libsodium-sumo.mjs. pnpm's strict node_modules
# isolation prevents this relative import from resolving.
# shamefully-hoist=true hoists all packages to the root node_modules,
# which fixes this module resolution issue.
#
# TIP: This is a common requirement when using Cardano libraries
# with pnpm. The alternative is to use npm or yarn instead.
# ──────────────────────────────────────────────────────────────────
shamefully-hoist=true
